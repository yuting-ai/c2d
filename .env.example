# ── LLM Provider ("deepseek" | "anthropic" | "ollama") ──
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Local Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5-coder:7b

# ── Embedding ──
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Data Engine ──
DUCKDB_DATA_DIR=./data/processed
UPLOAD_DIR=./data/uploads
EXPORT_DIR=./data/exports

# ── Vector Database (Qdrant) ──
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=c2d_memory

# ── Session Storage ──
STORAGE_BACKEND=local
SQLITE_PATH=./data/c2d.sqlite

# ── Server ──
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=info
